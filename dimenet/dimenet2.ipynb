{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# DimeNet++ Training on QM9\n",
    "This notebook trains a DimeNet++ model on the QM9 dataset to predict the HOMO-LUMO gap (target index 4).\n",
    "\n",
    "**Note:** Training is configured for CPU as requested."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 11,
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Using device: cpu\n"
     ]
    }
   ],
   "source": [
    "import os\n",
    "import json\n",
    "import torch\n",
    "import torch.nn as nn\n",
    "from torch_geometric.datasets import QM9\n",
    "from torch_geometric.loader import DataLoader\n",
    "from torch_geometric.nn.models import DimeNetPlusPlus\n",
    "from tqdm.auto import tqdm\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "# Set device to CPU\n",
    "device = torch.device('cpu')\n",
    "print(f\"Using device: {device}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Dataset and Preprocessing\n",
    "We use the QM9 dataset and select target index 4 (HOMO-LUMO gap)."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 12,
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Total samples: 130782\n",
      "Train/Val/Test: 110000/10000/10782\n",
      "Target mean: 6.8865, std: 1.2542\n"
     ]
    }
   ],
   "source": [
    "TARGET_IDX = 4  # HOMO-LUMO gap\n",
    "\n",
    dataset = QM9(root='./data/QM9')\n",
        "dataset = dataset.shuffle()\n",
        "\n",
        "# Standard split: 110k train, 10k val, remainder test\n",
        "train_dataset = dataset[:110000]\n",
        "val_dataset   = dataset[110000:120000]\n",
        "test_dataset  = dataset[120000:]"
    "\n",
    "print(f\"Total samples: {len(dataset)}\")\n",
    "print(f\"Train/Val/Test: {len(train_dataset)}/{len(val_dataset)}/{len(test_dataset)}\")\n",
    "\n",
    "# Target normalization stats from training set only\n",
    "targets = torch.stack([data.y[0, TARGET_IDX] for data in train_dataset])\n",
    "target_mean = targets.mean().item()\n",
    "target_std  = targets.std().item()\n",
    "\n",
    "print(f\"Target mean: {target_mean:.4f}, std: {target_std:.4f}\")\n",
    "\n",
    "def normalize(y):\n",
    "    return (y - target_mean) / target_std\n",
    "\n",
    "def denormalize(y_norm):\n",
    "    return y_norm * target_std + target_mean"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 13,
   "metadata": {},
   "outputs": [],
   "source": [
    "# CPU training usually benefits from small batches and few workers\n",
    "batch_size = 16 \n",
    "train_loader = DataLoader(train_dataset, batch_size=batch_size, shuffle=True)\n",
    "val_loader   = DataLoader(val_dataset,   batch_size=batch_size, shuffle=False)\n",
    "test_loader  = DataLoader(test_dataset,  batch_size=batch_size, shuffle=False)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Model Configuration\n",
    "We save the configuration to a JSON file for reproducibility."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 14,
   "metadata": {},
   "outputs": [],
   "source": [
    "model_config = {\n",
    "    \"hidden_channels\": 64,\n",
    "    \"out_channels\": 1,\n",
    "    \"num_blocks\": 4,\n",
    "    \"num_spherical\": 4,\n",
    "    \"num_radial\": 4,\n",
    "    \"cutoff\": 5.0,\n",
    "    \"int_emb_size\": 64,\n",
    "    \"out_emb_channels\": 64,\n",
    "    \"basis_emb_size\": 32,\n",
    "    \"target_idx\": TARGET_IDX,\n",
    "    \"target_mean\": target_mean,\n",
    "    \"target_std\": target_std\n",
    "}\n",
    "\n",
    "with open('dimenet_config.json', 'w') as f:\n",
    "    json.dump(model_config, f)\n",
    "\n",
    "model = DimeNetPlusPlus(\n",
    "    hidden_channels=model_config[\"hidden_channels\"],\n",
    "    out_channels=model_config[\"out_channels\"],\n",
    "    num_blocks=model_config[\"num_blocks\"],\n",
    "    num_spherical=model_config[\"num_spherical\"],\n",
    "    num_radial=model_config[\"num_radial\"],\n",
    "    cutoff=model_config[\"cutoff\"],\n",
    "    int_emb_size=model_config[\"int_emb_size\"],\n",
    "    out_emb_channels=model_config[\"out_emb_channels\"],\n",
    "    basis_emb_size=model_config[\"basis_emb_size\"]\n",
    ").to(device)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Training and Evaluation Functions"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 15,
   "metadata": {},
   "outputs": [],
   "source": [
    "criterion = nn.L1Loss()  # MAE\n",
    "optimizer = torch.optim.Adam(model.parameters(), lr=1e-3, amsgrad=True)\n",
    "scheduler = torch.optim.lr_scheduler.ReduceLROnPlateau(\n",
    "    optimizer, mode='min', factor=0.5, patience=10, min_lr=1e-6\n",
    ")\n",
    "\n",
    "def train_one_epoch(model, loader, optimizer):\n",
    "    model.train()\n",
    "    total_loss = 0\n",
    "    for batch in tqdm(loader, desc=\"Training\"):\n",
    "        batch = batch.to(device)\n",
    "        optimizer.zero_grad()\n",
    "        \n",
    "        y = normalize(batch.y[:, TARGET_IDX])\n",
    "        out = model(batch.z, batch.pos, batch.batch)\n",
    "        \n",
    "        loss = criterion(out.squeeze(), y)\n",
    "        loss.backward()\n",
    "        optimizer.step()\n",
    "        total_loss += loss.item() * batch.num_graphs\n",
    "    return total_loss / len(loader.dataset)\n",
    "\n",
    "@torch.no_grad()\n",
    "def evaluate(model, loader):\n",
    "    model.eval()\n",
    "    total_mae = 0\n",
    "    for batch in loader:\n",
    "        batch = batch.to(device)\n",
    "        out = model(batch.z, batch.pos, batch.batch)\n",
    "        \n",
    "        preds = denormalize(out.squeeze())\n",
    "        labels = batch.y[:, TARGET_IDX]\n",
    "        total_mae += (preds - labels).abs().sum().item()\n",
    "    return total_mae / len(loader.dataset)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Training Loop"
   ]
